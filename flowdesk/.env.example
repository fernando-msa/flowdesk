# ============================================================
# FlowDesk — Variáveis de Ambiente
# Copie para .env.local e preencha antes de rodar
# ============================================================

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/flowdesk?schema=public"

# NextAuth — gere o secret com: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-por-um-valor-aleatorio-seguro"

# Uploadthing — upload de arquivos
# Crie uma conta em https://uploadthing.com e gere as chaves
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="seu-app-id"

# Opcional: e-mail (Resend) — para notificações futuras
# RESEND_API_KEY="re_..."
# EMAIL_FROM="noreply@seudominio.com.br"
